COMPOSE_PROJECT_NAME=parcelops
APP_ENV=development
DATABASE_ECHO=0

WEB_PORT=3000
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

POSTGRES_HOST=postgres
POSTGRES_DB=parcelops
POSTGRES_USER=parcelops
POSTGRES_PASSWORD=parcelops
DATABASE_URL=postgresql://parcelops:parcelops@postgres:5432/parcelops

REDIS_HOST=redis
REDIS_BROKER_DB=0
REDIS_RESULT_DB=1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
LOCAL_STORAGE_ROOT=/data/uploads
